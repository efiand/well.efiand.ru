{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedKeys": "on"
			}
		},
		"enabled": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!public"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"linter": {
		"domains": { "project": "all" },
		"enabled": true,
		"rules": {
			"complexity": {
				"noUselessStringConcat": "error",
				"useArrowFunction": "off"
			},
			"correctness": {
				"noUnusedFunctionParameters": "error",
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			},
			"performance": { "noAccumulatingSpread": "error" },
			"preset": "recommended",
			"style": {
				"useBlockStatements": "error",
				"useConst": {
					"fix": "none",
					"level": "error",
					"options": {}
				},
				"useDestructuring": "error",
				"useExponentiationOperator": "error",
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"filenameCases": ["kebab-case"],
						"strictCase": false
					}
				},
				"useImportType": "error",
				"useNodejsImportProtocol": "error",
				"useTemplate": "error"
			},
			"suspicious": {
				"noConsole": {
					"fix": "none",
					"level": "error",
					"options": { "allow": ["assert", "error", "info", "warn"] }
				},
				"noGlobalIsNan": "error",
				"noVar": "error"
			}
		}
	},
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
